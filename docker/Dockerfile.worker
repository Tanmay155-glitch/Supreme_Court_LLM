# ── ULI Worker Dockerfile (Celery — embedding + rerank) ─────────────────────
FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# Pre-download BGE reranker model to avoid cold-start latency
RUN python -c "from sentence_transformers import CrossEncoder; \
    CrossEncoder('BAAI/bge-reranker-large', max_length=512)" || true

COPY . .
RUN pip install -e . --no-deps

CMD ["celery", "-A", "uli.worker.celery_app", "worker", \
     "--loglevel=info", "--concurrency=2", "-Q", "embedding,reranking,default"]
