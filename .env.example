# ── ULI Environment Variables ─────────────────────────────────────────────────
# Copy to .env and fill in real values before running

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Pinecone
PINECONE_API_KEY=pc-your-key-here

# PostgreSQL
DB_PASSWORD=change_in_production

# NJDG (leave blank to use mock server)
NJDG_PRIVATE_KEY=
NJDG_KEY_ID=uli-key-1
NJDG_CLIENT_CERT=
NJDG_CLIENT_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# Feature flags
USE_MOCK_NJDG=true
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.98
MAX_LOOPS=3

# Grafana
GRAFANA_PASSWORD=admin
